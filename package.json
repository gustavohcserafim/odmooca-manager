{
  "name": "odmooca-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Volunteer schedule management system for Onda Dura Mooca church",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "test": "npm run test -w apps/web",
    "test:watch": "npm run test:watch -w apps/web",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  }
}
